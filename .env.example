# Privy - https://dashboard.privy.io
VITE_PRIVY_APP_ID=

# Server-side only - never use VITE_ prefix
PRIVY_APP_SECRET=

# AVNU Paymaster - https://portal.avnu.fi
AVNU_API_KEY=

# Neon Database - connection string from console.neon.tech
DATABASE_URL=

# Starknet
VITE_STARKNET_NETWORK=sepolia
STARKNET_RPC_URL=https://free-rpc.nethermind.io/sepolia-juno
cat > package.json << 'EOF'
{
  "name": "zaplink",
    "version": "1.0.0",
      "description": "Gasless onchain payment links powered by Starkzap",
        "private": true,
          "engines": { "node": "20.x" },
            "scripts": {
                "dev": "vite",
                    "build": "tsc && vite build",
                        "preview": "vite preview",
                            "typecheck": "tsc --noEmit"
                              },
                                "dependencies": {
                                    "@privy-io/react-auth": "2.4.1",
                                        "@privy-io/server-auth": "1.16.0",
                                            "starkzap": "0.3.1",
                                                "starknet": "7.3.1",
                                                    "@neondatabase/serverless": "0.10.4",
                                                        "qrcode": "1.5.4",
                                                            "nanoid": "5.0.9",
                                                                "react": "18.3.1",
                                                                    "react-dom": "18.3.1",
                                                                        "react-router-dom": "6.28.0"
                                                                          },
                                                                            "devDependencies": {
                                                                                "@vercel/node": "3.2.9",
                                                                                    "@types/qrcode": "1.5.5",
                                                                                        "@types/react": "18.3.12",
                                                                                            "@types/react-dom": "18.3.1",
                                                                                                "@types/node": "20.17.9",
                                                                                                    "@vitejs/plugin-react": "4.3.4",
                                                                                                        "typescript": "5.7.2",
                                                                                                            "vite": "6.0.5"
                                                                                                              }
                                                                                                              }
                                                                                                              EOF
                                                                                                              